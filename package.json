{
  "name": "@gzeu/taskmanagerpro",
  "version": "1.0.0",
  "description": "A production-ready mobile application for task management built with React Native, featuring Material Design UI, real-time sync, and comprehensive collaboration tools.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:android:debug": "cd android && ./gradlew assembleDebug",
    "build:ios": "cd ios && xcodebuild -workspace TaskManagerPro.xcworkspace -scheme TaskManagerPro -configuration Release",
    "build:ios:debug": "cd ios && xcodebuild -workspace TaskManagerPro.xcworkspace -scheme TaskManagerPro -configuration Debug",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e:android": "detox test --configuration android.emu.debug",
    "test:e2e:ios": "detox test --configuration ios.sim.debug",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,md}\"",
    "clean": "react-native clean",
    "clean:android": "cd android && ./gradlew clean",
    "clean:ios": "cd ios && xcodebuild clean && rm -rf ios/build",
    "clean:node": "rm -rf node_modules && npm install",
    "clean:metro": "npx react-native start --reset-cache",
    "clean:all": "npm run clean:node && npm run clean:android && npm run clean:ios && npm run clean:metro",
    "postinstall": "cd ios && pod install",
    "reset-cache": "react-native start --reset-cache",
    "pods": "cd ios && pod install",
    "pods:update": "cd ios && pod update",
    "generate:icons": "react-native generate-bootsplash --platforms=android,ios --background-color=FFFFFF --logo-width=150 assets/logo.png",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "bundle:ios": "react-native bundle --platform ios --dev false --entry-file index.js --bundle-output ios/main.jsbundle --assets-dest ios",
    "analyze:bundle": "npx react-native-bundle-visualizer",
    "dev:android": "concurrently \"npm start\" \"npm run android\"",
    "dev:ios": "concurrently \"npm start\" \"npm run ios\"",
    "adb:reverse": "adb reverse tcp:8081 tcp:8081",
    "adb:shake": "adb shell input keyevent 82",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags",
    "setup:dev": "npm install && npm run pods && npm run adb:reverse",
    "doctor": "react-native doctor",
    "info": "react-native info"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.21.0",
    "@react-native-community/netinfo": "^11.3.1",
    "@react-native-firebase/app": "^19.2.2",
    "@react-native-firebase/auth": "^19.2.2",
    "@react-native-firebase/firestore": "^19.2.2",
    "@react-native-firebase/messaging": "^19.2.2",
    "@react-native-firebase/storage": "^19.2.2",
    "@react-native-google-signin/google-signin": "^11.0.1",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/stack": "^6.3.29",
    "@reduxjs/toolkit": "^2.2.7",
    "date-fns": "^3.6.0",
    "dayjs": "^1.11.10",
    "i18next": "^23.11.5",
    "react": "18.2.0",
    "react-i18next": "^14.1.2",
    "react-native": "0.74.3",
    "react-native-app-intro-slider": "^4.0.4",
    "react-native-biometrics": "^3.0.1",
    "react-native-calendars": "^1.1305.0",
    "react-native-chart-kit": "^6.12.0",
    "react-native-date-picker": "^5.0.4",
    "react-native-document-picker": "^9.3.0",
    "react-native-draggable-flatlist": "^4.0.1",
    "react-native-encrypted-storage": "^4.0.3",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "^2.16.2",
    "react-native-keychain": "^8.2.0",
    "react-native-localize": "^3.0.6",
    "react-native-paper": "^5.12.3",
    "react-native-permissions": "^4.1.5",
    "react-native-push-notification": "^8.1.1",
    "react-native-reanimated": "^3.10.1",
    "react-native-safe-area-context": "^4.10.1",
    "react-native-screens": "^3.31.1",
    "react-native-share": "^10.2.1",
    "react-native-svg": "^15.2.0",
    "react-native-vector-icons": "^10.1.0",
    "react-redux": "^9.1.2",
    "redux-persist": "^6.0.0",
    "rrule": "^2.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native/babel-preset": "0.74.85",
    "@react-native/eslint-config": "0.74.85",
    "@react-native/metro-config": "0.74.85",
    "@react-native/typescript-config": "0.74.85",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.5.1",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.6",
    "@types/react-test-renderer": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "babel-jest": "^29.6.3",
    "babel-plugin-module-resolver": "^5.0.2",
    "concurrently": "^8.2.2",
    "detox": "^20.19.3",
    "eslint": "^8.19.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.6.3",
    "metro-react-native-babel-preset": "0.76.8",
    "prettier": "^3.3.2",
    "react-test-renderer": "18.2.0",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "keywords": [
    "react-native",
    "task-manager",
    "productivity",
    "mobile-app",
    "typescript",
    "redux",
    "firebase",
    "material-design"
  ],
  "author": {
    "name": "Gzeu",
    "email": "pricopgeorge@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gzeu/TaskManagerPro.git"
  },
  "bugs": {
    "url": "https://github.com/Gzeu/TaskManagerPro/issues"
  },
  "homepage": "https://github.com/Gzeu/TaskManagerPro#readme",
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|react-native-.*|@react-navigation)/)"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/__tests__/**",
      "!src/**/test/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "testMatch": [
      "**/__tests__/**/*.(ts|tsx|js)",
      "**/*.(test|spec).(ts|tsx|js)"
    ]
  },
  "detox": {
    "test-runner": "jest",
    "runner-config": "e2e/config.json",
    "configurations": {
      "android.emu.debug": {
        "type": "android.emulator",
        "binaryPath": "android/app/build/outputs/apk/debug/app-debug.apk",
        "build": "cd android && ./gradlew assembleDebug assembleAndroidTest -DtestBuildType=debug",
        "device": {
          "avdName": "Pixel_3a_API_34_extension_level_7_x86_64"
        }
      },
      "ios.sim.debug": {
        "type": "ios.simulator",
        "binaryPath": "ios/build/Build/Products/Debug-iphonesimulator/TaskManagerPro.app",
        "build": "xcodebuild -workspace ios/TaskManagerPro.xcworkspace -scheme TaskManagerPro -configuration Debug -sdk iphonesimulator -derivedDataPath ios/build",
        "device": {
          "type": "iPhone 15"
        }
      }
    }
  }
}